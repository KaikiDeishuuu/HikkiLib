---
import { getCollection } from 'astro:content';

interface Props {
  bookId: string;
  currentChapterSlug: string;
}

const { bookId, currentChapterSlug } = Astro.props;
const chapters = await getCollection('chapters', ({ data }) => data.bookId === bookId);
chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
const book = (await getCollection('books')).find((entry) => entry.id === bookId);
const hasChapters = chapters.length > 0;
---

<div id="floating-directory-root" aria-hidden="true" hidden>
  <div class="floating-directory-backdrop" data-directory-backdrop hidden></div>

  <div class="floating-directory-shell" data-directory-shell data-has-chapters={String(hasChapters)}>
    <aside
      class="floating-directory-panel"
      id="floating-directory-panel"
      data-directory-panel
      aria-hidden="true"
      aria-label={`${book?.data.title || 'Book'} chapter directory`}
    >
      <div class="floating-directory-header">
        <div>
          <p class="floating-directory-kicker">Book directory</p>
          <div class="floating-directory-title-row">
            <h2>{book?.data.title || '目录'}</h2>
            <span class="floating-directory-count">{chapters.length} chapters</span>
          </div>
        </div>

        <button class="floating-directory-close" type="button" data-directory-close aria-label="关闭目录">✕</button>
      </div>

      <div class="floating-directory-body">
        {hasChapters ? (
          <ol class="floating-directory-list">
            {chapters.map((chapter) => {
              const isCurrent = chapter.slug === currentChapterSlug;
              return (
                <li class="floating-directory-item">
                  <a
                    class:list={["floating-directory-link", { "is-current": isCurrent }]}
                    href={`/${bookId}/${chapter.slug}`}
                    aria-current={isCurrent ? 'page' : undefined}
                  >
                    <span class="floating-directory-index">
                      {chapter.data.isAppendix ? '附录' : String(chapter.data.chapterNumber).padStart(2, '0')}
                    </span>
                    <span class="floating-directory-copy">
                      <span class="floating-directory-item-title">{chapter.data.title}</span>
                      <span class="floating-directory-item-meta">
                        {isCurrent ? '当前章节' : 'Chapter'}
                      </span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ol>
        ) : (
          <p class="floating-directory-empty">当前书籍暂时没有可显示的章节目录。</p>
        )}
      </div>
    </aside>

    <button
      class="floating-directory-button"
      data-directory-button
      type="button"
      aria-controls="floating-directory-panel"
      aria-expanded="false"
      aria-label="打开章节目录"
      disabled={!hasChapters}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <span class="floating-directory-button-label">目录</span>
    </button>
  </div>
</div>

<style>
  :global(body.directory-panel-open) {
    overflow: hidden;
  }

  .floating-directory-shell {
    position: fixed;
    right: max(1rem, env(safe-area-inset-right));
    bottom: max(1rem, env(safe-area-inset-bottom));
    z-index: 400;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    pointer-events: none;
  }

  .floating-directory-shell[data-has-chapters='false'] {
    display: none;
  }

  .floating-directory-backdrop {
    position: fixed;
    inset: 0;
    z-index: 398;
    background: rgba(15, 23, 42, 0.32);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-quick);
  }

  .floating-directory-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .floating-directory-panel {
    width: min(23rem, calc(100vw - 1.5rem));
    max-height: min(72vh, 34rem);
    overflow: hidden;
    border-radius: 1.25rem;
    border: 1px solid var(--border-light);
    background: color-mix(in srgb, var(--surface-strong) 94%, transparent);
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.16);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.75rem) scale(0.98);
    transform-origin: bottom right;
    transition: opacity var(--transition-quick), transform var(--transition-quick), visibility var(--transition-quick);
    pointer-events: auto;
  }

  .floating-directory-panel.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .floating-directory-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 3.2rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid var(--border-light);
    background: color-mix(in srgb, var(--surface-strong) 92%, transparent);
    color: var(--text-primary);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    cursor: pointer;
    pointer-events: auto;
  }

  .floating-directory-button:hover,
  .floating-directory-button:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent) 28%, var(--border-light));
  }

  .floating-directory-button:disabled {
    display: none;
  }

  .floating-directory-button-label {
    color: var(--text-secondary);
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .floating-directory-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1rem 0.8rem;
    border-bottom: 1px solid var(--border-light);
  }

  .floating-directory-kicker {
    margin: 0 0 0.25rem;
    color: var(--text-tertiary);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .floating-directory-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .floating-directory-title-row h2 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.2;
    font-family: var(--font-sans);
  }

  .floating-directory-count {
    color: var(--text-tertiary);
    font-size: 0.82rem;
  }

  .floating-directory-close {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: var(--text-secondary);
    cursor: pointer;
  }

  .floating-directory-close:hover,
  .floating-directory-close:focus-visible {
    background: var(--accent-soft);
    color: var(--text-primary);
  }

  .floating-directory-body {
    max-height: min(56vh, 28rem);
    overflow: auto;
  }

  .floating-directory-list {
    list-style: none;
    margin: 0;
    padding: 0.6rem;
  }

  .floating-directory-item {
    margin: 0;
  }

  .floating-directory-link {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: start;
    width: 100%;
    padding: 0.8rem 0.9rem;
    border-radius: 0.9rem;
  }

  .floating-directory-link:hover,
  .floating-directory-link:focus-visible {
    background: color-mix(in srgb, var(--accent-soft) 70%, transparent);
  }

  .floating-directory-link.is-current {
    background: color-mix(in srgb, var(--accent-soft) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border-light));
  }

  .floating-directory-index {
    min-width: 1.75rem;
    color: var(--text-tertiary);
    font-size: 0.78rem;
    line-height: 1.6;
  }

  .floating-directory-copy {
    min-width: 0;
  }

  .floating-directory-item-title {
    display: block;
    line-height: 1.45;
    color: var(--text-primary);
    word-break: break-word;
  }

  .floating-directory-item-meta {
    display: block;
    margin-top: 0.14rem;
    color: var(--text-tertiary);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .floating-directory-empty {
    padding: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .floating-directory-shell {
      right: max(0.75rem, env(safe-area-inset-right));
      bottom: max(0.75rem, env(safe-area-inset-bottom));
    }

    .floating-directory-button {
      min-height: 3rem;
      padding: 0 0.9rem;
    }

    .floating-directory-panel {
      width: min(100vw - 1rem, 23rem);
      max-height: min(78vh, 32rem);
    }

    .floating-directory-body {
      max-height: min(62vh, 26rem);
    }
  }
</style>

<script>
  // @ts-nocheck
  const root = document.getElementById('floating-directory-root');

  if (root && !root.dataset.initialized) {
    root.dataset.initialized = 'true';

    const backdrop = root.querySelector('[data-directory-backdrop]');
    const shell = root.querySelector('[data-directory-shell]');
    const panel = root.querySelector('[data-directory-panel]');
    const button = root.querySelector('[data-directory-button]');
    const closeButton = root.querySelector('[data-directory-close]');
    const currentLink = root.querySelector('.floating-directory-link.is-current');
    const directoryLinks = root.querySelectorAll('.floating-directory-link');

    if (backdrop && shell) {
      document.body.append(backdrop, shell);
      root.remove();
    }

    const setOpen = (open) => {
      if (!backdrop || !panel || !button || !shell) return;
      if (shell.dataset.hasChapters === 'false') return;

      panel.classList.toggle('is-open', open);
      panel.setAttribute('aria-hidden', String(!open));
      button.setAttribute('aria-expanded', String(open));
      backdrop.classList.toggle('is-open', open);
      backdrop.hidden = !open;
      document.body.classList.toggle('directory-panel-open', open);

      if (open) {
        closeButton?.focus();
        currentLink?.scrollIntoView({ block: 'nearest' });
      }
    };

    button?.addEventListener('click', () => {
      const nextOpen = panel ? !panel.classList.contains('is-open') : false;
      setOpen(nextOpen);
    });

    closeButton?.addEventListener('click', () => {
      setOpen(false);
      button?.focus();
    });

    backdrop?.addEventListener('click', () => setOpen(false));

    directoryLinks.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setOpen(false);
        button?.focus();
      }
    });
  }
</script>
