---
import { getCollection } from 'astro:content';

interface Props {
  bookId: string;
}

const { bookId } = Astro.props;
const chapters = await getCollection('chapters', ({ data }) => data.bookId === bookId);
chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
---

<button id="toc-fab" class="toc-fab" type="button" aria-label="打开目录" aria-controls="toc-panel" aria-expanded="false">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
  <span>目录</span>
</button>

<div id="toc-mask" class="toc-mask" hidden></div>

<aside id="toc-panel" class="toc-panel" aria-hidden="true">
  <div class="toc-panel-head">
    <div>
      <p class="toc-kicker">Contents</p>
      <h3>目录</h3>
    </div>
    <button id="toc-close" type="button" aria-label="关闭目录">✕</button>
  </div>

  <ul class="toc-list">
    {chapters.map((ch) => (
      <li>
        <a href={`/${bookId}/${ch.slug}`}>
          <span class="toc-index">{ch.data.isAppendix ? '附录' : String(ch.data.chapterNumber).padStart(2, '0')}</span>
          <span class="toc-title">{ch.data.title}</span>
        </a>
      </li>
    ))}
  </ul>
</aside>

<style>
  .toc-fab {
    position: fixed !important;
    right: 1rem;
    bottom: 1rem;
    z-index: 250;
    height: 2.95rem;
    min-width: 2.95rem;
    padding: 0 .8rem;
    border-radius: 999px;
    border: 1px solid var(--border-light);
    background: color-mix(in srgb, var(--surface-strong) 90%, transparent);
    color: var(--text-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .38rem;
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition: opacity 140ms ease-out, transform 140ms ease-out, border-color 140ms ease-out;
  }

  .toc-fab span {
    font-size: .76rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .toc-fab:hover,
  .toc-fab:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent) 28%, var(--border-light));
  }

  .toc-fab.is-scrolling {
    opacity: .5;
  }

  .toc-mask {
    position: fixed;
    inset: 0;
    z-index: 240;
    background: rgba(0,0,0,.28);
  }

  .toc-panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 260;
    width: min(24rem, calc(100vw - 1.2rem));
    background: color-mix(in srgb, var(--surface-strong) 94%, transparent);
    border-right: 1px solid var(--border-light);
    box-shadow: 0 14px 40px rgba(0,0,0,.2);
    transform: translateX(-102%);
    transition: transform 170ms ease-out;
    display: flex;
    flex-direction: column;
  }

  .toc-panel.is-open {
    transform: translateX(0);
  }

  .toc-panel-head {
    padding: .95rem .9rem .75rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .6rem;
    border-bottom: 1px solid var(--border-light);
  }

  .toc-kicker {
    margin: 0 0 .22rem;
    color: var(--text-tertiary);
    font-size: .7rem;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .toc-panel-head h3 {
    margin: 0;
    font-size: 1.15rem;
    letter-spacing: -.02em;
  }

  #toc-close {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: var(--text-secondary);
  }

  #toc-close:hover,
  #toc-close:focus-visible {
    background: var(--accent-soft);
    color: var(--text-primary);
  }

  .toc-list {
    margin: 0;
    padding: .35rem .45rem .75rem;
    list-style: none;
    overflow-y: auto;
    flex: 1;
  }

  .toc-list li + li {
    border-top: 1px solid var(--border-light);
  }

  .toc-list a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: .75rem;
    align-items: start;
    padding: .95rem .5rem;
    border-radius: .75rem;
  }

  .toc-list a:hover,
  .toc-list a:focus-visible {
    background: color-mix(in srgb, var(--accent-soft) 74%, transparent);
  }

  .toc-index {
    color: var(--text-tertiary);
    font-size: .8rem;
    padding-top: .15rem;
  }

  .toc-title {
    line-height: 1.5;
    color: var(--text-primary);
  }

  @supports (bottom: env(safe-area-inset-bottom)) {
    .toc-fab {
      bottom: calc(1rem + env(safe-area-inset-bottom));
    }
  }

  @media (max-width: 720px) {
    .toc-fab {
      right: .9rem;
      bottom: .9rem;
      height: 2.85rem;
      min-width: 2.85rem;
      padding: 0 .72rem;
    }

    .toc-fab span {
      font-size: .72rem;
    }

    .toc-panel {
      width: calc(100vw - .55rem);
    }
  }
</style>

<script>
  const fab = document.getElementById('toc-fab');
  const panel = document.getElementById('toc-panel');
  const mask = document.getElementById('toc-mask');
  const closeBtn = document.getElementById('toc-close');
  const links = panel?.querySelectorAll('a');

  const setOpen = (open) => {
    if (!panel || !mask || !fab) return;
    panel.classList.toggle('is-open', open);
    panel.setAttribute('aria-hidden', open ? 'false' : 'true');
    mask.hidden = !open;
    fab.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  };

  fab?.addEventListener('click', () => setOpen(true));
  closeBtn?.addEventListener('click', () => setOpen(false));
  mask?.addEventListener('click', () => setOpen(false));
  links?.forEach((a) => a.addEventListener('click', () => setOpen(false)));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });

  let timer;
  const onScroll = () => {
    if (!fab) return;
    fab.classList.add('is-scrolling');
    clearTimeout(timer);
    timer = setTimeout(() => fab.classList.remove('is-scrolling'), 180);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
