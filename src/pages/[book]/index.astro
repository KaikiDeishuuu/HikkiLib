---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { book: book.id },
    props: { book },
  }));
}

const { book } = Astro.props;
const chapters = await getCollection('chapters', ({ data }) => {
  return data.bookId === book.id;
});

chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
---

<BaseLayout title={`${book.data.title} - HikkiLib`} description={book.data.description}>
  <main class="book-container page-frame">
    <header class="book-header">
      <a href="/" class="eyebrow-link">← 返回书架</a>
      <p class="section-kicker">Book Overview</p>
      <h1>{book.data.title}</h1>
      <p class="author">{book.data.author}</p>

      <div class="tags">
        {book.data.tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>

      <p class="desc">{book.data.description}</p>

      {chapters.length > 0 && (
        <a href={`/${book.id}/${chapters[0].slug}`} class="start-reading">
          开始阅读
        </a>
      )}
    </header>

    <section class="toc editorial-panel">
      <div class="toc-heading">
        <div>
          <p class="section-kicker">Contents</p>
          <h2>目录</h2>
        </div>
        <p class="toc-copy">共 {chapters.length} 章，按顺序展开。</p>
      </div>

      <ul class="chapter-list">
        {chapters.map(chapter => (
          <li>
            <a href={`/${book.id}/${chapter.slug}`}>
              <span class="chap-num">{String(chapter.data.chapterNumber).padStart(2, '0')}</span>
              <span class="chap-title">{chapter.data.title}</span>
              <span class="chap-arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .book-container {
    padding: var(--space-8) 0 var(--space-9);
    display: grid;
    gap: var(--space-7);
  }

  .book-header {
    max-width: 42rem;
    display: grid;
    gap: var(--space-3);
  }

  .book-header h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 4.1rem);
    line-height: 1.03;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .author {
    margin: 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: var(--space-2);
  }

  .tag {
    padding: 0.45rem 0.8rem;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--text-secondary);
    font-size: 0.83rem;
    letter-spacing: 0.02em;
  }

  .desc {
    margin: var(--space-2) 0 0;
    max-width: 38rem;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.84;
  }

  .start-reading {
    justify-self: start;
    margin-top: var(--space-3);
    padding: 0.88rem 1.4rem;
    border-radius: var(--radius-pill);
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 0.98rem;
    letter-spacing: -0.01em;
    box-shadow: var(--shadow-card);
  }

  .start-reading:hover,
  .start-reading:focus-visible {
    transform: translateY(-2px);
    opacity: 0.94;
  }

  .toc {
    padding: clamp(1.25rem, 2.8vw, 2rem);
  }

  .toc-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-light);
  }

  .toc-heading h2,
  .toc-copy {
    margin: 0;
  }

  .toc-heading h2 {
    font-size: 1.55rem;
    letter-spacing: -0.03em;
  }

  .toc-copy {
    color: var(--text-secondary);
    font-size: 0.96rem;
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chapter-list li + li {
    border-top: 1px solid var(--border-light);
  }

  .chapter-list a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: 1rem 0.1rem;
    border-radius: 0.75rem;
  }

  .chapter-list a:hover,
  .chapter-list a:focus-visible {
    color: var(--text-primary);
    transform: translateX(2px);
  }

  .chap-num,
  .chap-arrow {
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }

  .chap-title {
    font-size: 1.03rem;
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .book-container {
      padding: var(--space-7) 0 var(--space-8);
    }

    .toc-heading {
      flex-direction: column;
      align-items: flex-start;
    }

    .chapter-list a {
      grid-template-columns: auto 1fr;
    }

    .chap-arrow {
      display: none;
    }
  }
</style>
