---
import BaseLayout from './BaseLayout.astro';
import '../styles/typography.css';

interface Props {
  title: string;
  description?: string;
  prevUrl?: string;
  nextUrl?: string;
}

const { title, description, prevUrl, nextUrl } = Astro.props;
---

<BaseLayout title={title} description={description} type="article">
  <style>
    .reader-container {
      position: relative;
      padding: var(--space-8) 0 var(--space-9);
    }

    .progress-wrap {
      position: sticky;
      top: var(--nav-height);
      height: 1px;
      background: color-mix(in srgb, var(--border-light) 55%, transparent);
      z-index: 11;
      pointer-events: none;
      width: min(calc(100% - 2rem), calc(var(--content-max-width) + 5rem));
      margin: 0 auto;
    }

    .progress-bar {
      height: 100%;
      width: 100%;
      background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 84%, white 16%), var(--accent));
      transform-origin: left center;
      transform: scaleX(var(--scroll-progress, 0));
      transition: transform 120ms ease-out;
    }


    .reader-card {
      width: min(calc(100% - 2rem), calc(var(--content-max-width) + 5rem));
      margin: 0 auto;
      padding: clamp(1.4rem, 2.8vw, 2.4rem) clamp(1rem, 3.2vw, 2.5rem) clamp(2rem, 4vw, 3rem);
      background: color-mix(in srgb, var(--surface-strong) 88%, transparent);
      border: 1px solid var(--border-light);
      border-radius: clamp(1.25rem, 3vw, 2rem);
      box-shadow: var(--shadow-soft);
    }

    .reader-nav {
      width: min(calc(100% - 2rem), calc(var(--content-max-width) + 5rem));
      margin: var(--space-7) auto 0;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-4);
    }

    .reader-link,
    .reader-link-placeholder {
      min-height: 5.4rem;
      padding: var(--space-4) var(--space-5);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-light);
      background: color-mix(in srgb, var(--surface) 88%, transparent);
    }

    .reader-link {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 0.6rem;
      box-shadow: var(--shadow-card);
    }

    .reader-link:hover,
    .reader-link:focus-visible {
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--accent) 28%, var(--border-light));
      box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
    }

    .reader-link-label {
      color: var(--text-tertiary);
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .reader-link-title {
      color: var(--text-primary);
      font-size: 1rem;
      line-height: 1.45;
    }

    .reader-link.next {
      text-align: right;
      align-items: flex-end;
    }

    .reader-link-placeholder {
      background: transparent;
      box-shadow: none;
    }

    @media (max-width: 720px) {
      .reader-container {
        padding: var(--space-7) 0 var(--space-8);
      }

      .progress-wrap,
      .reader-card,
      .reader-nav {
        width: min(calc(100% - 1.25rem), calc(var(--content-max-width) + 5rem));
      }

      .reader-nav {
        grid-template-columns: 1fr;
      }

      .reader-link.next {
        text-align: left;
        align-items: flex-start;
      }

      .reader-link,
      .reader-link-placeholder {
        min-height: 0;
      }

      .reader-link:hover,
      .reader-link:focus-visible {
        transform: none;
        box-shadow: var(--shadow-card);
      }
    }
  </style>

  <div class="progress-wrap" aria-hidden="true">
    <div class="progress-bar" id="reading-progress"></div>
  </div>

  <section class="reader-container">
    <div class="reader-card">
      <article class="reader-content">
        <slot />
      </article>
    </div>

    <nav class="reader-nav" aria-label="Chapter Navigation">
      {prevUrl ? (
        <a href={prevUrl} rel="prefetch" class="reader-link">
          <span class="reader-link-label">Previous</span>
          <span class="reader-link-title">← 上一章 / 返回目录</span>
        </a>
      ) : <div class="reader-link-placeholder" aria-hidden="true"></div>}

      {nextUrl ? (
        <a href={nextUrl} rel="prefetch" class="reader-link next">
          <span class="reader-link-label">Next</span>
          <span class="reader-link-title">下一章 / 返回目录 →</span>
        </a>
      ) : <div class="reader-link-placeholder" aria-hidden="true"></div>}
    </nav>
  </section>

  <script>
    const updateProgress = () => {
      const scrollY = window.scrollY;
      const height = document.body.scrollHeight - window.innerHeight;
      const progress = height > 0 ? scrollY / height : 0;
      document.documentElement.style.setProperty('--scroll-progress', progress.toString());
    };

    updateProgress();
    window.addEventListener('scroll', () => {
      requestAnimationFrame(updateProgress);
    }, { passive: true });
  </script>
</BaseLayout>
